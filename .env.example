# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
# Note: MLflow UI accessible at http://localhost:5001 (host port)
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# Gmail SMTP Alert
GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_RECIPIENT=alert-recipient@gmail.com

# Drift threshold (0.0 - 1.0)
DRIFT_THRESHOLD=0.5

# Batch schedule interval in minutes
BATCH_SCHEDULE_INTERVAL_MINUTES=60
